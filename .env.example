# Database Configuration
DATABASE_URL=postgres://postgres:dev123@localhost:5432/videoconverter?sslmode=disable
MONGODB_URI=mongodb://admin:dev123@localhost:27017/videoconverter?authSource=admin
REDIS_URL=redis://:dev123@localhost:6379
RABBITMQ_URL=amqp://admin:dev123@localhost:5672/

# Object Storage (MinIO — S3-compatible)
# MinIO replaces MongoDB GridFS for video and MP3 file storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=dev123456
MINIO_BUCKET=videos
MINIO_USE_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Service URLs
AUTH_SERVICE_URL=localhost:50051
ANALYTICS_SERVICE_URL=localhost:8000
GATEWAY_SERVICE_URL=localhost:8080
REALTIME_SERVICE_URL=localhost:3001

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# Development Configuration
WORKER_POOL_SIZE=5
LOG_LEVEL=debug