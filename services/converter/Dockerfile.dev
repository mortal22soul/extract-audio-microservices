FROM golang:alpine AS dev

WORKDIR /app

# Install FFmpeg and development tools
RUN apk add --no-cache git make ffmpeg

# Install air for live reload
RUN go install github.com/air-verse/air@latest

# Copy shared module
COPY shared/ ../shared/

# Copy go mod files
COPY services/converter/go.mod services/converter/go.sum ./
RUN go mod download

# Copy source code
COPY services/converter/ .

# Build the application
RUN go build -o bin/converter ./cmd/main.go

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD echo "Converter service health check placeholder" || exit 1

# Run the application
CMD ["./bin/converter"]